 السؤال: إيه اتجاه المبيعات عبر الزمن (شهريًا)؟ — Trend Analysis
بنحسب متوسط السعر، إجمالي المبيعات، إجمالي الكمية، وعدد العملاء المميزين لكل شهر وسنة.
sqlSELECT
    YEAR(order_date)                    AS order_year,
    DATENAME(MONTH, order_date)         AS order_month,
    AVG(price)                          AS avg_price,
    SUM(total_sales)                    AS amount_sales,
    SUM(quantity)                       AS total_quantity,
    COUNT(DISTINCT customer_key)        AS total_customer
FROM gold.fact_sales
GROUP BY
    YEAR(order_date),
    DATENAME(MONTH, order_date)
ORDER BY
    YEAR(order_date) DESC,
    DATENAME(MONTH, order_date) DESC;




 السؤال: إيه المتوسط المتحرك للسعر والإجمالي التراكمي للمبيعات سنويًا؟ — Cumulative Analysis (Moving Average & Running Total)
بنحسب لكل سنة: متوسط السعر، متوسط متحرك (Moving Average) للسعر، إجمالي المبيعات، وإجمالي تراكمي (Running Total) للمبيعات.
sqlSELECT
    order_year,
    avg_price,
    AVG(avg_price) OVER (ORDER BY avg_price)   AS moving_avg_price,
    amount_sales,
    SUM(amount_sales) OVER (ORDER BY amount_sales) AS running_total_sales
FROM (
    SELECT
        YEAR(order_date) AS order_year,
        AVG(price)       AS avg_price,
        SUM(total_sales) AS amount_sales
    FROM gold.fact_sales
    GROUP BY YEAR(order_date)
) t;




السؤال: أداء كل منتج سنويًا مقارنة بمتوسط مبيعاته على مر السنين، ومقارنة بالسنة اللي قبلها؟ — 
Performance Analysis (Year-over-Year + Average Comparison)
بنحسب لكل منتج في كل سنة: المبيعات الحالية، الفرق عن متوسط مبيعاته العام (Above/Below Avg)، والفرق عن مبيعات السنة السابقة (Increase/Decrease) — تحليل Year-over-Year.
sqlWITH yearly_product_sales AS (
    SELECT
        YEAR(f.order_date) AS order_year,
        p.product_name,
        SUM(f.total_sales) AS current_sales
    FROM gold.fact_sales f
    LEFT JOIN gold.dim_product p
        ON f.product_key = p.product_key
    WHERE f.order_date IS NOT NULL
    GROUP BY
        YEAR(f.order_date),
        p.product_name
)
SELECT
    order_year,
    product_name,
    current_sales,
    AVG(current_sales) OVER (PARTITION BY product_name) AS avg_sales,
    current_sales - AVG(current_sales) OVER (PARTITION BY product_name) AS diff_avg,
    CASE
        WHEN current_sales - AVG(current_sales) OVER (PARTITION BY product_name) > 0 THEN 'Above Avg'
        WHEN current_sales - AVG(current_sales) OVER (PARTITION BY product_name) < 0 THEN 'Below Avg'
        ELSE 'Avg'
    END AS avg_change,
    -- Year-over-Year Analysis
    LAG(current_sales) OVER (PARTITION BY product_name ORDER BY order_year) AS py_sales,
    current_sales - LAG(current_sales) OVER (PARTITION BY product_name ORDER BY order_year) AS diff_py,
    CASE
        WHEN current_sales - LAG(current_sales) OVER (PARTITION BY product_name ORDER BY order_year) > 0 THEN 'Increase'
        WHEN current_sales - LAG(current_sales) OVER (PARTITION BY product_name ORDER BY order_year) < 0 THEN 'Decrease'
        ELSE 'No Change'
    END AS py_change
FROM yearly_product_sales
ORDER BY product_name, order_year;





السؤال: كل تصنيف (Category) بينساهم بنسبة كام من إجمالي المبيعات والكمية؟ — Part-to-Whole Analysis
بنحسب لكل category إجمالي المبيعات والكمية، ثم نسبة مساهمتها من الإجمالي الكلي.
  WITH category_sales AS (
    SELECT
        p.category            AS category,
        SUM(f.total_sales)    AS amount_sales,
        SUM(f.quantity)       AS total_quantity
    FROM gold.fact_sales f
    LEFT JOIN gold.dim_product p
        ON f.product_key = p.product_key
    GROUP BY p.category
)
SELECT
    category,
    amount_sales,
    total_quantity,
    SUM(total_quantity) OVER () AS overall_qty,
    SUM(amount_sales) OVER ()   AS overall_sales,
    CONCAT(ROUND((CAST(amount_sales AS FLOAT) / SUM(amount_sales) OVER ()) * 100, 2), '%')   AS pct_cat_sales,
    CONCAT(ROUND((CAST(total_quantity AS FLOAT) / SUM(total_quantity) OVER ()) * 100, 2), '%') AS pct_cat_qty
FROM category_sales
ORDER BY amount_sales DESC, total_quantity DESC;



 السؤال: إيه توزيع المنتجات حسب فئات التكلفة (Cost Range)؟ — Data Segmentation
بنقسّم المنتجات لفئات حسب تكلفتها (Below 100, 100-500, 500-1000, Above 1000) ونحسب عدد المنتجات في كل فئة.
   WITH product_segments AS (
    SELECT
        product_key,
        product_name,
        product_cost,
        CASE
            WHEN product_cost < 100                       THEN 'Below 100'
            WHEN product_cost BETWEEN 100 AND 500          THEN '100-500'
            WHEN product_cost BETWEEN 500 AND 1000         THEN '500-1000'
            ELSE 'Above 1000'
        END AS cost_range
    FROM gold.dim_product
)
SELECT
    cost_range,
    COUNT(product_key) AS total_products
FROM product_segments
GROUP BY cost_range
ORDER BY total_products DESC;


 السؤال: العملاء بينقسموا لإيه فئات (VIP / Regular / New) حسب مدة تعاملهم وإجمالي إنفاقهم، وكام عميل في كل فئة؟ — Customer Segmentation
بنحسب لكل عميل إجمالي إنفاقه ومدة تعامله (Lifespan بالشهور)، وبناءً عليهم نصنّفه VIP / Regular / New، ثم نعد عدد العملاء في كل فئة.
   WITH customer_spending AS (
    SELECT
        c.customer_key,
        SUM(f.total_sales)                              AS total_spending,
        MIN(order_date)                                 AS first_order,
        MAX(order_date)                                 AS last_order,
        DATEDIFF(MONTH, MIN(order_date), MAX(order_date)) AS lifespan
    FROM gold.fact_sales f
    LEFT JOIN gold.dim_customer c
        ON f.customer_key = c.customer_key
    GROUP BY c.customer_key
)
SELECT
    customer_segment,
    COUNT(customer_key) AS total_customer
FROM (
    SELECT
        customer_key,
        total_spending,
        lifespan,
        CASE
            WHEN lifespan > 12 AND total_spending > 5000  THEN 'VIP'
            WHEN lifespan >= 12 AND total_spending <= 5000 THEN 'Regular'
            ELSE 'New'
        END AS customer_segment
    FROM customer_spending
) t
GROUP BY customer_segment
ORDER BY total_customer DESC;


















